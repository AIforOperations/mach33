__pycache__/
*.pyc
.DS_Store

# Secrets and per-machine working files are NOT committed.
# The .env is given to each teammate separately and dropped into the repo root by hand during
# setup. It holds the dummy KLAVIYO_API_KEY and, for real clients, one account PER STORE
# (KLAVIYO_STORE_<SLUG>_*). Those real keys CANNOT be rotated, so a single leak is permanent:
# `.env*` also catches .env.bak (wire's backup) and any .env.<x>; .env.example IS committed.
# The .githooks/pre-commit scan is the backstop if something is force-added.
.env
.env.*
!.env.example
builds/

# Keys are imported via a CSV (the store spreadsheet exported for `klaviyo.py wire`), holding raw
# unrotatable keys. Ignore ALL .csv so no key file can be committed regardless of its name; nothing
# in this repo is a tracked .csv. The .githooks/pre-commit scan also blocks a forced add.
*.csv

# Real per-brand translation data (glossaries + memory) stays LOCAL. Never commit client
# data to this public repo. Only the generic "example" is tracked as a format reference;
# any other brand's glossary/memory is built up during use and ignored here.
.claude/skills/figma_to_klaviyo/references/translation/glossaries/*
!.claude/skills/figma_to_klaviyo/references/translation/glossaries/example.json
.claude/skills/figma_to_klaviyo/references/translation/memory/*
!.claude/skills/figma_to_klaviyo/references/translation/memory/example/

# Dev-only agents stay LOCAL (the team that RUNS the skill doesn't need them). Only the
# translator agent, which the skill invokes, is shipped.
.claude/agents/*
!.claude/agents/translator.md
figma_export_comparison/

# Playwright's screenshot/log scratch dir, and stray root-level render/verify screenshots.
# Real design assets live in builds/ (ignored); no .png is ever tracked at the repo root.
.playwright-mcp/
/*.png
